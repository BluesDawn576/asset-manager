<Window x:Class="AssetManager.Desktop.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Width="380"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource OkButton}"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Content="{DynamicResource CancelButton}"
                    Width="82"
                    IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock x:Name="PromptText" Margin="0,0,0,6" />
            <TextBox x:Name="ValueBox" />
        </StackPanel>
    </DockPanel>
</Window>
