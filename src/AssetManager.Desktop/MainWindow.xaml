<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AssetManager.Desktop"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        Title="{DynamicResource AppTitle}"
        Loaded="Window_Loaded"
        Width="1440"
        Height="900"
        MinWidth="1040"
        MinHeight="640"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="84" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Padding" Value="0,2,0,2" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12" LastChildFill="True">
        <Menu DockPanel.Dock="Top"
              Background="White"
              BorderBrush="#D6DCE5"
              BorderThickness="1"
              IsEnabled="{Binding CanInteract}"
              Margin="0,0,0,8">
            <MenuItem Header="{DynamicResource MenuFile}">
                <MenuItem Header="{DynamicResource RegisterLibraryButton}" Click="RegisterLibrary_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource NewFolderButton}" Click="NewFolder_Click" InputGestureText="Ctrl+Shift+N" />
                <MenuItem Header="{DynamicResource NewTextButton}" Click="NewText_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource ImportFilesButton}" Click="ImportFiles_Click" InputGestureText="Ctrl+I" />
                <MenuItem Header="{DynamicResource ImportFolderButton}" Click="ImportFolder_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuEdit}">
                <MenuItem Header="{DynamicResource CopyButton}" Click="CopySelection_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuView}">
                <MenuItem Header="{DynamicResource ThumbnailFieldsButton}" Click="ThumbnailFieldsButton_Click" />
                <MenuItem x:Name="PinDetailsPanelMenuItem"
                          Header="{DynamicResource PinDetailsPanelMenuItem}"
                          IsCheckable="True"
                          IsChecked="{Binding IsDetailsPanelPinned, Mode=OneWay}"
                          Click="PinDetailsPanel_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuLibrary}">
                <MenuItem Header="{DynamicResource RefreshLibrariesButton}" Click="RefreshLibraries_Click" />
                <MenuItem Header="{DynamicResource SyncButton}" Click="Sync_Click" InputGestureText="F5" />
                <Separator />
                <MenuItem x:Name="LowImpactImportMenuItem"
                          Header="{DynamicResource LowImpactImportLabel}"
                          ToolTip="{DynamicResource LowImpactImportTooltip}"
                          IsCheckable="True"
                          IsChecked="{Binding IsLowImpactImportEnabled, Mode=OneWay}"
                          Click="LowImpactImportCheckBox_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuSettings}">
                <MenuItem Header="{DynamicResource LanguageLabel}"
                          ItemsSource="{Binding LanguageOptions}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding DisplayName}" />
                            <EventSetter Event="Click" Handler="LanguageMenuItem_Click" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#D6DCE5"
                BorderThickness="1"
                Padding="10"
                IsEnabled="{Binding CanInteract}"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource LibraryLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="#334155" />
                    <ComboBox x:Name="KnownLibraryBox"
                              Width="360"
                              ItemsSource="{Binding KnownLibraries}"
                              DisplayMemberPath="DisplayText"
                              SelectionChanged="KnownLibraryBox_SelectionChanged" />
                    <Button Content="{DynamicResource NewFolderButton}"
                            Click="NewFolder_Click"
                            ToolTip="Ctrl+Shift+N" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <Button Content="{DynamicResource ImportFilesButton}"
                                Click="ImportFiles_Click"
                                Margin="0"
                                ToolTip="Ctrl+I" />
                        <Button x:Name="ImportDropDownButton"
                                Content="▼"
                                MinWidth="28"
                                Padding="6,6"
                                Margin="0"
                                Click="ImportDropDown_Click">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource ImportFilesButton}" Click="ImportFiles_Click" />
                                    <MenuItem Header="{DynamicResource ImportFolderButton}" Click="ImportFolder_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                    <Button Content="{DynamicResource SyncButton}"
                            Click="Sync_Click"
                            ToolTip="F5" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBox x:Name="SearchBox"
                             Width="260"
                             ToolTip="{DynamicResource SearchTooltip}"
                             KeyDown="SearchBox_KeyDown" />
                    <TextBox x:Name="TagFilterBox"
                             Width="180"
                             ToolTip="{DynamicResource TagFilterTooltip}"
                             KeyDown="SearchBox_KeyDown" />
                    <Button
                             Content="{DynamicResource SearchButton}"
                             Click="Search_Click"
                             MinWidth="72" />
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Margin="0,10,0,0"
                   Background="White"
                   BorderBrush="#D6DCE5"
                   BorderThickness="1">
            <StatusBarItem Padding="8,2">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="{DynamicResource BackgroundTasksLabel}"
                               FontWeight="SemiBold"
                               Foreground="#334155"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding BackgroundTaskStatusMessage}"
                               Foreground="#475569"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0" />
                    <Button Content="{DynamicResource BackgroundTasksButton}"
                            MinWidth="92"
                            Padding="10,2"
                            Margin="0"
                            Click="BackgroundTasks_Click" />
                </DockPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#475569"
                           TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentFolderMessage}"
                               Foreground="#64748B"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="260" />
                    <TextBlock Text="  |  " Foreground="#CBD5E1" />
                    <TextBlock Text="{Binding LibraryRootMessage}"
                               Foreground="#64748B"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="420" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid IsEnabled="{Binding CanInteract}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="160" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="DetailsSplitterColumn" Width="3" />
                <ColumnDefinition x:Name="DetailsColumn" Width="360" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Padding="10"
                               FontWeight="SemiBold"
                               Text="{DynamicResource FoldersHeader}" />
                    <TreeView x:Name="FolderTree"
                              ItemsSource="{Binding FolderRoots}"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectedItemChanged="FolderTree_SelectedItemChanged">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:LibraryFolderNode}"
                                                      ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding DisplayName}" />
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1">
                <Grid AllowDrop="True"
                      Drop="AssetGrid_Drop"
                      DragOver="AssetGrid_DragOver">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top"
                                   Margin="12,12,12,8"
                                   LastChildFill="False">
                            <TextBlock Text="{DynamicResource ThumbnailViewHeader}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding DetailsPanelToggleText}"
                                    MinWidth="92"
                                    Margin="8,0,0,0"
                                    Click="ToggleDetailsPanel_Click" />
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource ThumbnailFieldsButton}"
                                    MinWidth="120"
                                    Click="ThumbnailFieldsButton_Click" />
                        </DockPanel>

                        <ListBox x:Name="AssetList"
                                 ItemsSource="{Binding Assets}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.CanContentScroll="True"
                                 SelectionMode="Extended"
                                 SelectionChanged="AssetList_SelectionChanged"
                                 PreviewMouseLeftButtonDown="AssetList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="AssetList_PreviewMouseMove"
                                 PreviewMouseWheel="AssetList_PreviewMouseWheel"
                                 local:VirtualizingTilePanel.VerticalOffsetChanged="AssetTilePanel_VerticalOffsetChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <local:VirtualizingTilePanel ItemWidth="{Binding AssetTileWidth}"
                                                                 ItemHeight="{Binding AssetTileHeight}"
                                                                 OverscanRows="1" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,12,12" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:AssetRow}">
                                    <Border x:Name="CardBorder"
                                            Width="{Binding DataContext.AssetCardWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            Height="{Binding DataContext.AssetCardHeight, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            Background="#FCFDFE"
                                            BorderBrush="#D6DCE5"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Background="#E8EEF5"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <Image gif:AnimationBehavior.SourceUri="{Binding AnimatedImageUri}"
                                                           Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAnimated}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Image Source="{Binding ThumbnailImageUri}"
                                                           Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding HasThumbnailImage}" Value="True" />
                                                                            <Condition Binding="{Binding IsAnimated}" Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Border Background="#DCE6F2"
                                                            CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPreviewImage}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding PlaceholderText}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#334155"
                                                                   TextAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="GIF"
                                                               FontWeight="Bold"
                                                               FontSize="11"
                                                               Foreground="White"
                                                               Background="#FF6B35"
                                                               Padding="4,1"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Top"
                                                               Margin="0,4,4,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsAnimated}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,8,0,6"
                                                       MaxHeight="42"
                                                       TextTrimming="CharacterEllipsis" />

                                            <ItemsControl Grid.Row="2"
                                                          ItemsSource="{Binding ThumbnailFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type local:ThumbnailFieldDisplay}">
                                                        <DockPanel Margin="0,0,0,3"
                                                                   LastChildFill="True">
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       Text="{Binding Label}"
                                                                       Foreground="#64748B"
                                                                       Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding Value}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="#2563EB" />
                                            <Setter TargetName="CardBorder" Property="Background" Value="#EFF6FF" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          DragCompleted="DetailsGridSplitter_DragCompleted"
                          Visibility="{Binding DetailsPanelVisibility}" />

            <Border Grid.Column="4"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1"
                    Padding="12"
                    Visibility="{Binding DetailsPanelVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DetailsHeader}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <TextBlock x:Name="SelectedNameText"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource NoAssetSelected}" />
                        <TextBlock x:Name="SelectedPathText"
                                   Margin="0,4,0,10"
                                   Foreground="#64748B" />

                        <TextBlock Text="{DynamicResource NotesLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="NotesBox"
                                 MinHeight="72"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="{DynamicResource TagsLabel}" Margin="0,6,0,4" />
                        <TextBox x:Name="TagsBox"
                                 ToolTip="{DynamicResource TagsTooltip}" />

                        <Button Content="{DynamicResource SaveMetadataButton}"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,14"
                                Click="SaveMetadata_Click" />

                        <TextBlock Text="{DynamicResource PreviewHeader}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                MinHeight="260"
                                Padding="8">
                            <Grid>
                                <Image x:Name="ImagePreview"
                                       Stretch="Uniform"
                                       Visibility="Collapsed" />
                                <StackPanel x:Name="MediaPreviewPanel"
                                            Visibility="Collapsed">
                                    <MediaElement x:Name="MediaPreview"
                                                  Height="230"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="{DynamicResource PlayButton}" Click="PlayPreview_Click" />
                                        <Button Content="{DynamicResource PauseButton}" Click="PausePreview_Click" />
                                        <Button Content="{DynamicResource StopButton}" Click="StopPreview_Click" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBox x:Name="TextPreview"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Visibility="Collapsed" />
                                <TextBlock x:Name="UnsupportedPreviewText"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="#64748B"
                                           Text="{DynamicResource SelectAssetToPreview}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
