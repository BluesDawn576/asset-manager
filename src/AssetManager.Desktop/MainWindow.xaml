<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Manager"
        Width="1100"
        Height="720"
        Background="#FFF5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="88" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12" LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#D6DCE5"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Copy" Click="CopySelection_Click" />
                <Button Content="Clear" Click="ClearAll_Click" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#5E6570"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <Border Background="White"
                BorderBrush="#D6DCE5"
                BorderThickness="1">
            <Grid AllowDrop="True"
                  Drop="RootGrid_Drop"
                  DragOver="RootGrid_DragOver">
                <ListView x:Name="AssetList"
                          ItemsSource="{Binding Assets}"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionMode="Extended"
                          PreviewMouseLeftButtonDown="AssetList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="AssetList_PreviewMouseMove">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding DisplayName}" Width="260" />
                            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding ItemKind}" Width="120" />
                            <GridViewColumn Header="Path" DisplayMemberBinding="{Binding SourcePath}" Width="680" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </DockPanel>
</Window>
