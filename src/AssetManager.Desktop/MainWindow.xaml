<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Loaded="Window_Loaded"
        Width="1440"
        Height="900"
        MinWidth="1040"
        MinHeight="640"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="84" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12" LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#D6DCE5"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource LanguageLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="#334155" />
                    <ComboBox x:Name="LanguageBox"
                              Width="138"
                              ItemsSource="{Binding LanguageOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="LanguageBox_SelectionChanged" />
                    <TextBlock Text="{DynamicResource LibraryLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="#334155" />
                    <ComboBox x:Name="KnownLibraryBox"
                              Width="360"
                              ItemsSource="{Binding KnownLibraries}"
                              DisplayMemberPath="DisplayText"
                              SelectionChanged="KnownLibraryBox_SelectionChanged" />
                    <Button Content="{DynamicResource RegisterLibraryButton}" Click="RegisterLibrary_Click" />
                    <Button Content="{DynamicResource RefreshLibrariesButton}" Click="RefreshLibraries_Click" />
                    <Button Content="{DynamicResource NewFolderButton}" Click="NewFolder_Click" />
                    <Button Content="{DynamicResource ImportFilesButton}" Click="ImportFiles_Click" />
                    <Button Content="{DynamicResource ImportFolderButton}" Click="ImportFolder_Click" />
                    <Button Content="{DynamicResource NewTextButton}" Click="NewText_Click" />
                    <Button Content="{DynamicResource SyncButton}" Click="Sync_Click" />
                    <Button Content="{DynamicResource CopyButton}" Click="CopySelection_Click" />
                </WrapPanel>
                <DockPanel DockPanel.Dock="Bottom" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               Width="260"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               Text="{Binding CurrentFolderMessage}" />
                    <Button DockPanel.Dock="Right"
                            Content="{DynamicResource SearchButton}"
                            Click="Search_Click"
                            MinWidth="72" />
                    <TextBox x:Name="TagFilterBox"
                             DockPanel.Dock="Right"
                             Width="180"
                             ToolTip="{DynamicResource TagFilterTooltip}"
                             KeyDown="SearchBox_KeyDown" />
                    <TextBox x:Name="SearchBox"
                             MinWidth="260"
                             ToolTip="{DynamicResource SearchTooltip}"
                             KeyDown="SearchBox_KeyDown" />
                </DockPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           Foreground="#64748B"
                           Text="{Binding LibraryRootMessage}" />
            </DockPanel>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,10,0,0"
                   Foreground="#475569"
                   Text="{Binding StatusMessage}" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Padding="10"
                               FontWeight="SemiBold"
                               Text="{DynamicResource FoldersHeader}" />
                    <ListBox x:Name="FolderList"
                             ItemsSource="{Binding Folders}"
                             DisplayMemberPath="DisplayName"
                             BorderThickness="0"
                             SelectionChanged="FolderList_SelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1"
                    Margin="0,0,10,0">
                <Grid AllowDrop="True"
                      Drop="AssetGrid_Drop"
                      DragOver="AssetGrid_DragOver">
                    <ListView x:Name="AssetList"
                              ItemsSource="{Binding Assets}"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectionMode="Extended"
                              SelectionChanged="AssetList_SelectionChanged"
                              PreviewMouseLeftButtonDown="AssetList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="AssetList_PreviewMouseMove">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource AssetListNameHeader}" DisplayMemberBinding="{Binding DisplayName}" Width="190" />
                                <GridViewColumn Header="{DynamicResource AssetListTypeHeader}" DisplayMemberBinding="{Binding TypeText}" Width="72" />
                                <GridViewColumn Header="{DynamicResource AssetListStatusHeader}" DisplayMemberBinding="{Binding StatusText}" Width="78" />
                                <GridViewColumn Header="{DynamicResource AssetListTagsHeader}" DisplayMemberBinding="{Binding TagsText}" Width="150" />
                                <GridViewColumn Header="{DynamicResource AssetListPathHeader}" DisplayMemberBinding="{Binding RelativePath}" Width="310" />
                                <GridViewColumn Header="{DynamicResource AssetListSizeHeader}" DisplayMemberBinding="{Binding SizeText}" Width="90" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D6DCE5"
                    BorderThickness="1"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DetailsHeader}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <TextBlock x:Name="SelectedNameText"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource NoAssetSelected}" />
                        <TextBlock x:Name="SelectedPathText"
                                   Margin="0,4,0,10"
                                   Foreground="#64748B" />

                        <TextBlock Text="{DynamicResource NotesLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="NotesBox"
                                 MinHeight="72"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="{DynamicResource TagsLabel}" Margin="0,6,0,4" />
                        <TextBox x:Name="TagsBox"
                                 ToolTip="{DynamicResource TagsTooltip}" />

                        <Button Content="{DynamicResource SaveMetadataButton}"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,14"
                                Click="SaveMetadata_Click" />

                        <TextBlock Text="{DynamicResource PreviewHeader}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                MinHeight="260"
                                Padding="8">
                            <Grid>
                                <Image x:Name="ImagePreview"
                                       Stretch="Uniform"
                                       Visibility="Collapsed" />
                                <StackPanel x:Name="MediaPreviewPanel"
                                            Visibility="Collapsed">
                                    <MediaElement x:Name="MediaPreview"
                                                  Height="230"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="{DynamicResource PlayButton}" Click="PlayPreview_Click" />
                                        <Button Content="{DynamicResource PauseButton}" Click="PausePreview_Click" />
                                        <Button Content="{DynamicResource StopButton}" Click="StopPreview_Click" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBox x:Name="TextPreview"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Visibility="Collapsed" />
                                <TextBlock x:Name="UnsupportedPreviewText"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="#64748B"
                                           Text="{DynamicResource SelectAssetToPreview}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
