<Window x:Class="AssetManager.Desktop.TextSnippetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TextSnippetTitle}"
        Width="560"
        Height="420"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource CreateButton}"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Create_Click" />
            <Button Content="{DynamicResource CancelButton}"
                    Width="82"
                    IsCancel="True" />
        </StackPanel>
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="{DynamicResource FileNameLabel}" Margin="0,0,0,4" />
                <TextBox x:Name="FileNameBox"
                         Text="snippet.txt"
                         Margin="0,0,0,10" />
                <TextBlock Text="{DynamicResource ContentLabel}" Margin="0,0,0,4" />
            </StackPanel>
            <TextBox x:Name="ContentBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </DockPanel>
    </DockPanel>
</Window>
