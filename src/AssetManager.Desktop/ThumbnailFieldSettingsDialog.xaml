<Window x:Class="AssetManager.Desktop.ThumbnailFieldSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ThumbnailSettingsDialogTitle}"
        Width="380"
        Height="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="14" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource OkButton}"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Content="{DynamicResource CancelButton}"
                    Width="82"
                    IsCancel="True" />
        </StackPanel>

        <StackPanel>
            <TextBlock Text="{DynamicResource ThumbnailSettingsDialogHint}"
                       Foreground="#475569"
                       Margin="0,0,0,10" />
            <CheckBox Content="{DynamicResource AssetListTypeHeader}"
                      IsChecked="{Binding ShowType}"
                      Margin="0,0,0,8" />
            <CheckBox Content="{DynamicResource AssetListStatusHeader}"
                      IsChecked="{Binding ShowStatus}"
                      Margin="0,0,0,8" />
            <CheckBox Content="{DynamicResource TagsLabel}"
                      IsChecked="{Binding ShowTags}"
                      Margin="0,0,0,8" />
            <CheckBox Content="{DynamicResource AssetListPathHeader}"
                      IsChecked="{Binding ShowPath}"
                      Margin="0,0,0,8" />
            <CheckBox Content="{DynamicResource AssetListSizeHeader}"
                      IsChecked="{Binding ShowSize}" />
        </StackPanel>
    </DockPanel>
</Window>
